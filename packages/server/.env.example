# Copy to .env (loaded by your process manager) to configure the server.
PORT=4000
SESSION_SECRET=change-me-to-a-long-random-string
DB_PATH=./data/automationsolver.sqlite
CLIENT_ORIGIN=http://localhost:5173
SERVER_ORIGIN=http://localhost:4000

# OAuth is optional. Leave blank to disable a provider.
# Google callback URL: {SERVER_ORIGIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub callback URL: {SERVER_ORIGIN}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Set to 1 when behind a reverse proxy terminating TLS.
TRUST_PROXY=0

# Email is optional. Leave SMTP_HOST blank to log verification/reset links to
# the console instead of sending real email (useful for local dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AutomationSolver <no-reply@automationsolver.local>
