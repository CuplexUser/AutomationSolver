{
  "name": "automationsolver",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w @automationsolver/server\" \"npm run dev -w @automationsolver/client\"",
    "build": "npm run build -w @automationsolver/client",
    "build:pages": "node scripts/build-pages.mjs",
    "test": "npm run test -w @automationsolver/shared && npm run test -w @automationsolver/server",
    "test:shared": "npm run test -w @automationsolver/shared",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "seed": "npm run seed -w @automationsolver/server"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  }
}
